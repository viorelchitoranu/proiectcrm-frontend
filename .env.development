# Folosit automat de Vite când rulezi `npm run dev`
# Nu comite acest fișier dacă conține secrete (dar acesta nu conține)

# URL-ul backend-ului în development (folosit de proxy în vite.config.js)
VITE_DEV_BACKEND_URL=http://localhost:8080

# Baza URL pentru API-uri în dev (lasă gol = proxy Vite gestionează /api/*)
VITE_API_BASE=
